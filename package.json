{
  "name": "@heroku-cli/plugin-api",
  "description": "access the Heroku API directly",
  "version": "3.0.4",
  "author": "Heroku",
  "bugs": {
    "url": "https://github.com/heroku/heroku-api-plugin/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@heroku-cli/command": "13.0.0-beta.1",
    "@heroku/http-call": "^5.4.0",
    "@oclif/core": "^4.3.0",
    "ansis": "^4",
    "edit-string": "^1.1.6",
    "get-stdin": "^10.0.0",
    "tsheredoc": "^1.0.1"
  },
  "devDependencies": {
    "@heroku-cli/test-utils": "^0.2.0",
    "@types/chai": "^5.0.1",
    "@types/mocha": "^10.0.6",
    "@types/node": "22.15.21",
    "c8": "^10.1.3",
    "chai": "^5.1.2",
    "eslint": "^9.39.4",
    "eslint-config-oclif": "^6.0.144",
    "eslint-plugin-mocha": "^11.2.0",
    "mocha": "^11.7.5",
    "nock": "^14.0.1",
    "oclif": "^4.22.81",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "oclif.manifest.json",
    "dist"
  ],
  "homepage": "https://github.com/heroku/heroku-api-plugin",
  "keywords": [
    "heroku-plugin"
  ],
  "license": "ISC",
  "oclif": {
    "bin": "heroku",
    "commands": "./dist/commands"
  },
  "repository": "heroku/heroku-api-plugin",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "lint": "eslint .",
    "postpublish": "rm oclif.manifest.json",
    "posttest": "npm run lint",
    "prepare": "npm run build",
    "prepack": "npm run build && oclif manifest",
    "pretest": "npm run build && oclif manifest",
    "test": "c8 mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md"
  },
  "type": "module",
  "//overrides": "serialize-javascript: mocha transitive dep, pinned for CVE-2024-11831",
  "overrides": {
    "serialize-javascript": "^7.0.5"
  }
}
