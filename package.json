{
  "name": "@heroku-cli/plugin-api",
  "description": "access the Heroku API directly",
  "version": "4.0.1",
  "author": "Heroku",
  "bugs": {
    "url": "https://github.com/heroku/heroku-api-plugin/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@heroku-cli/command": "13.0.1",
    "@heroku/http-call": "^5.4.0",
    "@oclif/core": "^4.3.0",
    "@heroku/heroku-cli-util": "^10.8.0",
    "@inquirer/external-editor": "^3.0.3",
    "get-stdin": "^10.0.0",
    "tsheredoc": "^1.0.1"
  },
  "devDependencies": {
    "@heroku-cli/test-utils": "^0.3.0",
    "@types/node": "22.15.21",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-config-oclif": "^6.0.144",
    "eslint-plugin-vitest": "^0.5.4",
    "nock": "^14.0.1",
    "oclif": "^4.23.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "files": [
    "oclif.manifest.json",
    "dist"
  ],
  "homepage": "https://github.com/heroku/heroku-api-plugin",
  "keywords": [
    "heroku-plugin"
  ],
  "license": "ISC",
  "oclif": {
    "bin": "heroku",
    "commands": "./dist/commands"
  },
  "repository": "heroku/heroku-api-plugin",
  "scripts": {
    "build": "rm -rf dist && tsc && oclif manifest && oclif readme",
    "lint": "eslint .",
    "postpublish": "rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepare": "npm run build",
    "test": "vitest run --coverage",
    "version": "oclif readme && git add README.md"
  },
  "type": "module",
  "//overrides": "serialize-javascript: mocha transitive dep, pinned for CVE-2024-11831",
  "overrides": {
    "serialize-javascript": "^7.0.5"
  }
}
